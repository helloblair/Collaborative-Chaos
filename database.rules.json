{
  "rules": {
    "boards": {
      "$boardId": {
        "presence": {
          ".read": "auth != null",
          "$sessionId": {
            ".write": "auth != null"
          }
        },
        "dragging": {
          ".read": "auth != null",
          "$objectId": {
            ".write": "auth != null && (!data.exists() || data.child('userId').val() == auth.uid)"
          }
        }
      }
    }
  }
}
