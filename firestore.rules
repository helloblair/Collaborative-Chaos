rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Guard: board exists AND caller is a member.
    // Using exists() before get() prevents a null-dereference when the
    // board document has been deleted mid-session.
    function isBoardMember(boardId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/boards/$(boardId))
        && request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.members;
    }

    match /boards/{boardId} {
      // get: allow members to read; also allow reads of non-existent docs so the
      // client can distinguish "not found" from "forbidden" (resource == null when doc missing).
      allow get: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.members);

      // list: only members' own boards are returned by the where() query.
      // Firestore validates that the query constraint (array-contains uid) is
      // equivalent to this rule, so the query is permitted.
      allow list: if request.auth != null
        && request.auth.uid in resource.data.members;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;

      // Members can update; non-members can self-join via invite link.
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members
        || (
          request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.auth.uid in request.resource.data.members
          && request.resource.data.memberEmails.hasAll(resource.data.memberEmails)
          && request.resource.data.memberEmails.size() == resource.data.memberEmails.size() + 1
        )
      );

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      match /items/{itemId} {
        allow read, write: if isBoardMember(boardId);
      }

      match /connectors/{connectorId} {
        allow read, write: if isBoardMember(boardId);
      }
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
